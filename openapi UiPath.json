{
  "openapi": "1.0.0",
  "info": {
    "title": "Mail Chain Summarizer",
    "version": "1.4.1",
    "description": "Minimal REST API to summarize email threads"
  },
  "servers": [
    {
      "url": "https://mailsummarizer.onrender.com"
    }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Service is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "example": "ok"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/summarize": {
      "post": {
        "summary": "Summarize email thread",
        "operationId": "summarizeEmail",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "text": {
                    "type": "string",
                    "description": "Full email chain text",
                    "example": "Hi team, final version sent. Can we review tomorrow?"
                  }
                },
                "required": ["text"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "summary": {
                      "type": "string",
                      "example": "The team shared the final version and plans to review it tomorrow."
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad request"
          },
          "500": {
            "description": "Internal server error"
          }
        }
      }
    }
  }
}
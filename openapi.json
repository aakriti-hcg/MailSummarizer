{
  "openapi": "1.0.1",
  "info": {
    "title": "Mail Chain Summarizer API",
    "version": "1.0.0",
    "description": "Minimal REST API to summarize email threads; exposes a simple /summarize and an OpenAI-style /v1/chat/completions."
  },
  "servers": [
    { "url": "http://127.0.0.1:8010" }
  ],
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Health Check",
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "Service is up",
            "content": {
              "application/json": {
                "schema": { "type": "object", "properties": { "status": { "type": "string", "example": "ok" } } }
              }
            }
          }
        }
      }
    },
    "/summarize": {
      "post": {
        "summary": "Summarize Mail Chain (simple)",
        "operationId": "summarizeSimple",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["text"],
                "properties": {
                  "text": { "type": "string", "description": "Full mail chain text" }
                }
              },
              "examples": {
                "basic": {
                  "value": {
                    "text": "Hi team, please find the attached report.\n\nCan we send by EOD?\nYes, final version sent."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Summary response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "summary": { "type": "string" } }
                }
              }
            }
          },
          "400": { "description": "Invalid input" },
          "401": { "description": "Unauthorized (if token enforced)" }
        },
        "security": [
          { "bearerAuth": [] },
          { "apiKeyAuth": [] },
          {}
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": { "type": "apiKey", "in": "header", "name": "x-api-key" },
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Message": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant"] },
          "content": { "type": "string" }
        }
      },
      "ChatRequest": {
        "type": "object",
        "required": ["messages"],
        "properties": {
          "model": { "type": "string", "example": "tiny-mail-llm" },
          "messages": { "type": "array", "items": { "$ref": "#/components/schemas/Message" }, "minItems": 1 },
          "temperature": { "type": "number", "default": 0.3 },
          "max_tokens": { "type": "integer", "default": 120 }
        }
      },
      "ChatChoice": {
        "type": "object",
        "properties": {
          "index": { "type": "integer", "example": 0 },
          "message": { "type": "object", "properties": { "role": { "type": "string", "example": "assistant" }, "content": { "type": "string" } } },
          "finish_reason": { "type": "string", "example": "stop" }
        }
      },
      "Usage": {
        "type": "object",
        "properties": {
          "prompt_tokens": { "type": "integer" },
          "completion_tokens": { "type": "integer" },
          "total_tokens": { "type": "integer" }
        }
      },
      "ChatResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "object": { "type": "string", "example": "chat.completion" },
          "choices": { "type": "array", "items": { "$ref": "#/components/schemas/ChatChoice" } },
          "usage": { "$ref": "#/components/schemas/Usage" }
        }
      }
    }
  }
}